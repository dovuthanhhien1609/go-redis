@startuml concurrent-clients
title Concurrent Clients — RWMutex Behaviour

skinparam backgroundColor #FAFAFA
skinparam defaultFontName "DejaVu Sans"
skinparam defaultFontSize 12

skinparam participant {
    BackgroundColor #DDEEFF
    BorderColor #336699
}

skinparam note {
    BackgroundColor #FFFDE7
    BorderColor #F9A825
}

== Two concurrent SET commands — serialize at write lock ==

participant "Goroutine A\n(client 1 SET)" as A
participant "MemoryStore\nRWMutex" as MU
participant "Goroutine B\n(client 2 SET)" as B

A -> MU : mu.Lock()
activate MU #DDEEFF
note over MU : write lock held by A
B -> MU : mu.Lock()
note over B : BLOCKED — waiting for A
A -> MU : data["k1"] = "v1"
A -> MU : mu.Unlock()
deactivate MU
MU -> B : lock acquired
activate MU #FFDDDD
B -> MU : data["k2"] = "v2"
B -> MU : mu.Unlock()
deactivate MU

== Two concurrent GET commands — run in parallel via RLock ==

participant "Goroutine C\n(client 3 GET)" as C
participant "MemoryStore\nRWMutex" as MU2
participant "Goroutine D\n(client 4 GET)" as D

C -> MU2 : mu.RLock()
activate MU2 #DDEEFF
D -> MU2 : mu.RLock()
note over MU2 : both readers proceed\nconcurrently — no blocking
C -> MU2 : data["k1"] read
D -> MU2 : data["k2"] read
C -> MU2 : mu.RUnlock()
D -> MU2 : mu.RUnlock()
deactivate MU2

@enduml
